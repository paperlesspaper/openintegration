{
  "name": "@paperlesspaper/openintegration",
  "version": "0.1.3",
  "description": "Tiny helper toolkit for static paperlesspaper OpenIntegration pages.",
  "type": "module",
  "sideEffects": [
    "dist/paperless.css",
    "dist/preview.css"
  ],
  "bin": {
    "paperlesspaper-openintegration": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./paperless.css": "./dist/paperless.css",
    "./preview.css": "./dist/preview.css",
    "./paperless.js": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/paperless.js"
    },
    "./paperless.iife.js": "./dist/paperless.iife.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "npm run build && node dist/cli.js dev",
    "test": "npm run build && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "epdoptimize": "^1.3.0",
    "puppeteer-core": "^25.1.0"
  }
}
